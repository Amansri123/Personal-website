rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && request.auth.token.email == 'amansrivastava1995gzp@gmail.com' && request.auth.token.email_verified == true;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    // --- Inquiries Collection ---
    match /inquiries/{inquiryId} {
      allow create: if isValidInquiry(incoming());
      allow read: if isAdmin();
      allow update, delete: if isAdmin();
    }

    function isValidInquiry(data) {
      return data.keys().hasAll(['name', 'email', 'message', 'createdAt'])
        && data.keys().size() == 4
        && data.name is string && data.name.size() > 0 && data.name.size() <= 100
        && data.email is string && data.email.size() > 0 && data.email.size() <= 100 && data.email.matches('.+@.+\\..+')
        && data.message is string && data.message.size() > 0 && data.message.size() <= 5000
        && data.createdAt == request.time;
    }
  }
}
